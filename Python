import tkinter as tk
from tkinter import messagebox
import random
import time

class Minesweeper:
    def __init__(self, master, rows=9, cols=9, mines=10):
        self.master = master
        self.rows = rows
        self.cols = cols
        self.mines = mines
        self.buttons = []
        self.revealed = [[False for _ in range(cols)] for _ in range(rows)]
        self.flags = [[False for _ in range(cols)] for _ in range(rows)]
        self.mine_positions = set()
        self.numbers = [[0 for _ in range(cols)] for _ in range(rows)]
        self.game_over = False
        self.first_click = True
        self.start_time = None
        self.timer_id = None
        
        self.create_widgets()
        self.reset_display()
    
    def create_widgets(self):
        top_frame = tk.Frame(self.master)
        top_frame.pack()
        self.mine_label = tk.Label(top_frame, text=f"💣 {self.mines}", font=("Arial", 16))
        self.mine_label.pack(side=tk.LEFT, padx=10)
        self.timer_label = tk.Label(top_frame, text="⏱️ 000", font=("Arial", 16))
        self.timer_label.pack(side=tk.RIGHT, padx=10)
        
        self.frame = tk.Frame(self.master)
        self.frame.pack()
        for r in range(self.rows):
            row = []
            for c in range(self.cols):
                btn = tk.Button(self.frame, width=2, height=1, font=("Arial", 12))
                btn.bind('<Button-1>', lambda e, row=r, col=c: self.left_click(row, col))
                btn.bind('<Button-3>', lambda e, row=r, col=c: self.right_click(row, col))
                btn.grid(row=r, column=c)
                row.append(btn)
            self.buttons.append(row)
    
    def reset_display(self):
        for r in range(self.rows):
            for c in range(self.cols):
                self.buttons[r][c].config(text="", bg="SystemButtonFace")
                self.revealed[r][c] = False
                self.flags[r][c] = False
        self.game_over = False
        self.first_click = True
        self.start_time = None
        if self.timer_id:
            self.master.after_cancel(self.timer_id)
        self.timer_label.config(text="⏱️ 000")
        self.mine_label.config(text=f"💣 {self.mines}")
    
    def generate_mines(self, first_r, first_c):
        self.mine_positions.clear()
        safe_cells = set()
        for dr in [-1,0,1]:
            for dc in [-1,0,1]:
                nr, nc = first_r+dr, first_c+dc
                if 0 <= nr < self.rows and 0 <= nc < self.cols:
                    safe_cells.add((nr, nc))
        safe_cells.add((first_r, first_c))
        
        available = [(r,c) for r in range(self.rows) for c in range(self.cols) if (r,c) not in safe_cells]
        self.mine_positions = set(random.sample(available, self.mines))
        
        # Вычисляем числа
        for r in range(self.rows):
            for c in range(self.cols):
                if (r,c) in self.mine_positions:
                    self.numbers[r][c] = -1
                else:
                    cnt = 0
                    for dr in [-1,0,1]:
                        for dc in [-1,0,1]:
                            nr, nc = r+dr, c+dc
                            if 0 <= nr < self.rows and 0 <= nc < self.cols and (nr,nc) in self.mine_positions:
                                cnt += 1
                    self.numbers[r][c] = cnt
    
    def left_click(self, r, c):
        if self.game_over:
            return
        if self.first_click:
            self.generate_mines(r, c)
            self.first_click = False
            self.start_time = time.time()
            self.update_timer()
        if self.flags[r][c]:
            return
        if self.revealed[r][c]:
            return
        if (r,c) in self.mine_positions:
            self.game_over = True
            self.reveal_mines()
            messagebox.showinfo("Game Over", "You hit a mine!")
            return
        self.reveal_cell(r,c)
        self.check_win()
    
    def reveal_cell(self, r, c):
        if not (0 <= r < self.rows and 0 <= c < self.cols):
            return
        if self.revealed[r][c] or self.flags[r][c]:
            return
        self.revealed[r][c] = True
        val = self.numbers[r][c]
        if val == 0:
            self.buttons[r][c].config(text="", bg="lightgray")
            for dr in [-1,0,1]:
                for dc in [-1,0,1]:
                    if dr==0 and dc==0: continue
                    self.reveal_cell(r+dr, c+dc)
        elif val == -1:
            self.buttons[r][c].config(text="💣", bg="red")
        else:
            color = ["blue","green","red","purple","maroon","turquoise","black","gray"][val-1]
            self.buttons[r][c].config(text=str(val), fg=color, bg="lightgray")
    
    def right_click(self, r, c):
        if self.game_over or self.revealed[r][c]:
            return
        if not self.flags[r][c]:
            self.flags[r][c] = True
            self.buttons[r][c].config(text="🚩")
        else:
            self.flags[r][c] = False
            self.buttons[r][c].config(text="")
        self.update_mine_counter()
    
    def update_mine_counter(self):
        flagged = sum(sum(row) for row in self.flags)
        self.mine_label.config(text=f"💣 {self.mines - flagged}")
    
    def reveal_mines(self):
        for r,c in self.mine_positions:
            if not self.revealed[r][c]:
                self.buttons[r][c].config(text="💣", bg="red")
    
    def check_win(self):
        revealed_count = sum(sum(row) for row in self.revealed)
        if revealed_count == self.rows * self.cols - self.mines:
            self.game_over = True
            elapsed = int(time.time() - self.start_time) if self.start_time else 0
            messagebox.showinfo("You win!", f"Congratulations! Time: {elapsed} sec")
    
    def update_timer(self):
        if self.game_over or self.first_click:
            return
        elapsed = int(time.time() - self.start_time)
        self.timer_label.config(text=f"⏱️ {elapsed:03d}")
        self.timer_id = self.master.after(1000, self.update_timer)

if __name__ == "__main__":
    root = tk.Tk()
    root.title("Minesweeper - Python")
    game = Minesweeper(root, 9,9,10)
    root.mainloop()
